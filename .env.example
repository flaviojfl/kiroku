# Conexão com o PostgreSQL.
# Troque usuario, senha e o nome do banco conforme a sua instalação local.
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:1234@localhost:5432/kiroku?schema=public"

# Segredo usado para assinar a sessão de login do organizador.
# Em produção, troque por um valor longo e aleatório.
AUTH_SECRET="asasdasdadfasdfsdfasdfasdfasdfadfasdfasd"
